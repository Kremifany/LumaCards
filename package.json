{
  "name": "lumacards",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma migrate deploy && prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.mjs",
    "populate:organic-chem-1": "node scripts/populate-organic-chem-1.mjs",
    "docker:up": "docker compose up -d --build",
    "docker:db:up": "docker compose up -d db",
    "docker:app:up": "docker compose up -d --build app",
    "docker:migrate": "docker compose run --rm app npx prisma migrate deploy",
    "docker:seed": "docker compose run --rm app sh -lc \"npx prisma generate && npm run prisma:seed\"",
    "docker:setup": "npm run docker:db:up && npm run docker:migrate && npm run docker:seed",
    "docker:run": "npm run docker:setup && npm run docker:app:up",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
